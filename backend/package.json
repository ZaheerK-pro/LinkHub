{
  "name": "linkhub-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"tsx src/index.ts\"",
    "dev:tsx": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typeorm": "typeorm-ts-node-esm -d src/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate src/migrations/AutoMigration",
    "migration:create": "npm run typeorm -- migration:create src/migrations/NewMigration",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "inversify": "^8.1.0",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "zod": "^3.23.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1"
  }
}
